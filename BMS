#include <stdio.h>
#include <string.h>
#include <ctype.h>

struct bank {
    int acc_no;
    char name[50];
    float balance;
    char mobile[11];
    char aadhaar[13];
    char pan[11];
};

struct bank b[100];
int count = 0;

// PAN check function
int checkPAN(char pan[]) {
    int i;

    for (i = 0; i < 5; i++) {
        if (!isalpha(pan[i])) return 0;
    }

    for (i = 5; i < 9; i++) {
        if (!isdigit(pan[i])) return 0;
    }

    if (!isalpha(pan[9])) return 0;

    return 1;
}

// Create Account
void createAccount() {
    if (count >= 100) {
    printf("Account limit reached!\n");
    return;
}
    printf("\n--- Create Account ---\n");

    printf("Enter Account Number: ");
    scanf("%d", &b[count].acc_no);

    printf("Enter Name: ");
    scanf("%s", b[count].name);

    printf("Enter Mobile Number (10 digit): ");
    scanf("%s", b[count].mobile);

    if (strlen(b[count].mobile) != 10) {
        printf("Invalid Mobile Number! Try Again.\n");
        return;
    }

    printf("Enter Aadhaar Number (12 digit): ");
    scanf("%s", b[count].aadhaar);

    if (strlen(b[count].aadhaar) != 12) {
        printf("Invalid Aadhaar Number! Try Again.\n");
        return;
    }

    printf("Enter PAN Card (ABCDE1234F): ");
    scanf("%s", b[count].pan);

    if (!checkPAN(b[count].pan)) {
        printf("Invalid PAN Number! Try Again.\n");
        return;
    }

    printf("Enter Balance: ");
    scanf("%f", &b[count].balance);

    count++;   // ✅ sirf yahan hona chahiye

    printf("Account Created Successfully!\n");
}

// Deposit
void deposit() {
    int acc, i;
    float amt;

    printf("\nEnter Account Number: ");
    scanf("%d", &acc);

    for (i = 0; i < count; i++) {
        if (b[i].acc_no == acc) {
            printf("Enter Amount: ");
            scanf("%f", &amt);

            b[i].balance += amt;
            printf("Money Deposited!\n");
            return;
        }
    }

    printf("Account Not Found!\n");
}

// Withdraw
void withdraw() {
    int acc, i;
    float amt;

    printf("\nEnter Account Number: ");
    scanf("%d", &acc);

    for (i = 0; i < count; i++) {
        if (b[i].acc_no == acc) {
            printf("Enter Amount: ");
            scanf("%f", &amt);

            if (b[i].balance >= amt) {
                b[i].balance -= amt;
                printf("Money Withdrawn!\n");
            } else {
                printf("Insufficient Balance!\n");
            }
            return;
        }
    }

    printf("Account Not Found!\n");
}

// Display
void displayAll() {
    int i;

    if (count == 0) {
        printf("\nNo Accounts Found!\n");
        return;
    }

    for (i = 0; i < count; i++) {
        printf("\nAcc No: %d", b[i].acc_no);
        printf("\nName: %s", b[i].name);
        printf("\nMobile: %s", b[i].mobile);
        printf("\nAadhaar: %s", b[i].aadhaar);
        printf("\nPAN: %s", b[i].pan);
        printf("\nBalance: %.2f\n", b[i].balance);
        printf("\nTotal Accounts: %d\n", count);
    }
}

// Search
void search() {
    int acc, i;

    printf("\nEnter Account Number: ");
    scanf("%d", &acc);

    for (i = 0; i < count; i++) {
        if (b[i].acc_no == acc) {
            printf("\nAccount Found!\n");
            printf("Name: %s\n", b[i].name);
            printf("Balance: %.2f\n", b[i].balance);
            return;
        }
    }

    printf("Account Not Found!\n");
}

// Delete
void deleteAccount() {
    int acc, i, index = -1;

    printf("\nEnter Account Number: ");
    scanf("%d", &acc);

    for (i = 0; i < count; i++) {
        if (b[i].acc_no == acc) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        printf("Account Not Found!\n");
        return;
    }

    for (i = index; i < count - 1; i++) {
        b[i] = b[i + 1];
    }

    count--;

    printf("Account Deleted Successfully!\n");
}

// Main
int main() {
    int choice;

    while (1) {
        printf("\n======= BANK MANAGEMENT SYSTEM =======\n");
        printf("1. Create Account\n");
        printf("2. Deposit Money\n");
        printf("3. Withdraw Money\n");
        printf("4. Display All Accounts\n");
        printf("5. Search Account\n");
        printf("6. Delete Account\n");
        printf("7. Exit\n");

        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: createAccount(); break;
            case 2: deposit(); break;
            case 3: withdraw(); break;
            case 4: displayAll(); break;
            case 5: search(); break;
            case 6: deleteAccount(); break;
            case 7: return 0;
            default: printf("Invalid Choice!\n");
        }
    }
}
