#include <stdio.h>
#include <string.h>

struct book {
    int id;
    char name[50];
    char author[50];
    char status[20];
};

struct book b[100];
int count = 0;

// Add Book
void addBook() {
    int i, id;

    printf("\n--- Add Book ---\n");

    printf("Enter Book ID: ");
    scanf("%d", &id);

    // 🔍 Duplicate check
    for (i = 0; i < count; i++) {
        if (b[i].id == id) {
            printf("Book ID already exists! Try another ID.\n");
            return;
        }
    }

    // ✅ Safe to add
    b[count].id = id;

    printf("Enter Book Name: ");
    scanf(" %[^\n]", b[count].name);

    printf("Enter Author Name: ");
    scanf(" %[^\n]", b[count].author);

    strcpy(b[count].status, "Available");

    count++;
    printf("Book Added Successfully!\n");
}


// Display All Books
void displayBooks() {
    int i;

    if (count == 0) {
        printf("No Books Available!\n");
        return;
    }

    for (i = 0; i < count; i++) {
        printf("\nID: %d", b[i].id);
        printf("\nName: %s", b[i].name);
        printf("\nAuthor: %s", b[i].author);
        printf("\nStatus: %s\n", b[i].status);
    }
}

// Search Book
void searchBook() {
    int id, i;

    printf("\nEnter Book ID: ");
    scanf("%d", &id);

    for (i = 0; i < count; i++) {
        if (b[i].id == id) {
            printf("\nBook Found!\n");
            printf("Name: %s\n", b[i].name);
            printf("Author: %s\n", b[i].author);
            printf("Status: %s\n", b[i].status);
            return;
        }
    }

    printf("Book Not Found!\n");
}

// Take Book
void takeBook() {
    int choice;
    printf("\n--- Take Book ---\n");
    printf("1. Through ID\n");
    printf("2. Through Name\n");
    printf("Enter Choice: ");
    scanf("%d", &choice);

    if (choice == 1) {
        int id, i;
        printf("Enter Book ID: ");
        scanf("%d", &id);

        for (i = 0; i < count; i++) {
            if (b[i].id == id) {
                if (strcmp(b[i].status, "Available") == 0) {
                    strcpy(b[i].status, "Taken");
                    printf("Book Taken Successfully!\n");
                } else {
                    printf("Book already taken!\n");
                }
                return;
            }
        }

        printf("Book Not Found!\n");
    }

    else if (choice == 2) {
        char name[50];
        int i, found = 0;

        printf("Enter Book Name: ");
        scanf("%s", name);

        for (i = 0; i < count; i++) {
            if (strcmp(b[i].name, name) == 0) {
                if (strcmp(b[i].status, "Available") == 0) {
                    strcpy(b[i].status, "Taken");
                    printf("\nBook Taken: %s\n", b[i].name);
                    found = 1;
                } else {
                    printf("\n%s already taken!\n", b[i].name);
                }
            }
        }

        if (!found) {
            printf("Book Not Found!\n");
        }
    }

    else {
        printf("Invalid Choice!\n");
    }
}

// Show Taken Books
void showTakenBooks() {
    int i, found = 0;

    printf("\n--- Taken Books ---\n");

    for (i = 0; i < count; i++) {
        if (strcmp(b[i].status, "Taken") == 0) {
            printf("\nID: %d", b[i].id);
            printf("\nName: %s", b[i].name);
            printf("\nAuthor: %s\n", b[i].author);
            found = 1;
        }
    }

    if (!found) {
        printf("No Taken Books Found!\n");
    }
}

// Return Book
void returnBook() {
    int id, i;

    printf("\nEnter Book ID: ");
    scanf("%d", &id);

    for (i = 0; i < count; i++) {
        if (b[i].id == id) {
            strcpy(b[i].status, "Available");
            printf("Book Returned Successfully!\n");
            return;
        }
    }

    printf("Book Not Found!\n");
}

// Delete Book
void deleteBook() {
    int id, i, index = -1;

    printf("\nEnter Book ID: ");
    scanf("%d", &id);

    for (i = 0; i < count; i++) {
        if (b[i].id == id) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        printf("Book Not Found!\n");
        return;
    }

    for (i = index; i < count - 1; i++) {
        b[i] = b[i + 1];
    }

    count--;

    printf("Book Deleted Successfully!\n");
}

// Main Function
int main() {
    int choice;

    while (1) {
        printf("\n===== LIBRARY MANAGEMENT SYSTEM =====\n");
        printf("1. Add Book\n");
        printf("2. Display All Books\n");
        printf("3. Search Book\n");
        printf("4. Take Book\n");
        printf("5. Show Taken Books\n");
        printf("6. Return Book\n");
        printf("7. Delete Book\n");
        printf("8. Exit\n");

        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addBook(); break;
            case 2: displayBooks(); break;
            case 3: searchBook(); break;
            case 4: takeBook(); break;
            case 5: showTakenBooks(); break;
            case 6: returnBook(); break;
            case 7: deleteBook(); break;
            case 8: return 0;
            default: printf("Invalid Choice!\n");
        }
    }
}
