#include <stdio.h>
#include <string.h>

struct student {
    char name[50];
    int roll;
    int marks;
};

struct student s[100];
int count = 0;

// Add Student
void addStudent() {
    printf("\nEnter Student Name: ");
    scanf(" %[^\n]", s[count].name);

    printf("Enter Roll No: ");
    scanf("%d", &s[count].roll);

    printf("Enter Marks: ");
    scanf("%d", &s[count].marks);

    count++;
    printf("Student Added Successfully!\n");
}

// Display All Students
void displayAll() {
    if (count == 0) {
        printf("\nNo records found!\n");
        return;
    }

    printf("\n--- Student Details ---\n");
    for (int i = 0; i < count; i++) {
        printf("\nRoll No: %d", s[i].roll);
        printf("\nName: %s", s[i].name);
        printf("\nMarks: %d\n", s[i].marks);
    }
}

// Search Student
void searchStudent() {
    int choice;
    printf("\nSearch By:\n1. Roll No\n2. Marks\n3. Name\nChoose: ");
    scanf("%d", &choice);

    // Search by Roll No
    if (choice == 1) {
        int roll, found = 0;
        printf("Enter Roll No: ");
        scanf("%d", &roll);

        for (int i = 0; i < count; i++) {
            if (s[i].roll == roll) {
                printf("\nFound:\nName: %s\nMarks: %d\n", s[i].name, s[i].marks);
                found = 1;
            }
        }
        if (!found) printf("Not Found!\n");
    }

    // Search by Marks
    else if (choice == 2) {
        int marks, found = 0;
        printf("Enter Marks: ");
        scanf("%d", &marks);

        for (int i = 0; i < count; i++) {
            if (s[i].marks == marks) {
                printf("\nRoll: %d | Name: %s\n", s[i].roll, s[i].name);
                found = 1;
            }
        }
        if (!found) printf("Not Found!\n");
    }

    // Search by Name (UPDATED - partial match)
    else if (choice == 3) {
        char name[50];
        int found = 0;

        printf("Enter Name: ");
        scanf(" %[^\n]", name);

        for (int i = 0; i < count; i++) {
            if (strstr(s[i].name, name) != NULL) {
                printf("\nRoll: %d | Name: %s | Marks: %d\n",
                       s[i].roll, s[i].name, s[i].marks);
                found = 1;
            }
        }

        if (!found) printf("No matching student found!\n");
    }

    else {
        printf("Invalid Choice!\n");
    }
}

// Delete Student
void deleteStudent() {
    int roll, index = -1;

    printf("\nEnter Roll No to delete: ");
    scanf("%d", &roll);

    for (int i = 0; i < count; i++) {
        if (s[i].roll == roll) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        printf("Student not found!\n");
        return;
    }

    printf("\nFound:\nName: %s | Marks: %d\n", s[index].name, s[index].marks);

    int confirm;
    printf("Press 1 to Delete, 2 to Back: ");
    scanf("%d", &confirm);

    if (confirm == 1) {
        for (int i = index; i < count - 1; i++) {
            s[i] = s[i + 1];
        }
        count--;
        printf("Deleted Successfully!\n");
    }
}

// Main Function
int main() {
    int choice;

    while (1) {
        printf("\n==============================\n");
        printf("   STUDENT MANAGEMENT SYSTEM\n");
        printf("==============================\n");

        printf("\n1. Add Student Detail");
        printf("\n2. Show All Students");
        printf("\n3. Search Student");
        printf("\n4. Delete Student");
        printf("\n5. Exit");

        printf("\n\nEnter Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                addStudent();
                break;

            case 2:
                displayAll();
                break;

            case 3:
                searchStudent();
                break;

            case 4:
                deleteStudent();
                break;

            case 5:
                printf("Exiting Program...\n");
                return 0;

            default:
                printf("Invalid Choice!\n");
        }
    }

    return 0;
}
